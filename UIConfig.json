{
  "page": {
    "label": "Maloja Configuration"
  },
  "sections": [
   {
      "id": "section_account",
      "element": "section",
      "label": "Maloja account",
      "icon": "fa-plug",
      "onSave": {"type":"controller", "endpoint":"music_service/maloja", "method":"saveMalojaAccount"},
      "saveButton": {
        "label": "Save",
        "data": [
          "url",
          "api_key"
        ]
      },
      "content": [
        {
          "id": "url",
          "type":"text",
          "element": "input",
          "doc": "This is the full URL to your Maloja server",
          "label": "Maloja URL",
          "value": "https://"
        },
        {
          "id": "api_key",
          "type":"password",
          "element": "input",
          "doc": "This is the API key for your Maloja server",
          "label": "API Key",
          "value": ""
        }
      ]
    }
  ]
}
